# Copiá este archivo a .env.local y completá con los datos de tu proyecto
# real de Supabase (Project Settings → API en supabase.com)

NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aca

# Service Role key (Project Settings → API → service_role)
# CRITICO: nunca poner el prefijo NEXT_PUBLIC_ en esta — si lo lleva,
# Next.js la manda al browser y cualquiera podría verla. Se usa SOLO
# en las API routes del servidor (lib/supabase/admin.ts).
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aca

# Emails del staff del gimnasio, separados por coma, sin espacios extra.
# Son los únicos que pueden entrar a /admin y marcar canjes como entregados.
STAFF_EMAILS=dueño@tugym.com,recepcion@tugym.com
